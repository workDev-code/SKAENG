PORT=8080

# Gemini API key (server-only). Never commit real keys.
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK:
# Option A: set GOOGLE_APPLICATION_CREDENTIALS to the service account JSON path.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
#
# Option B: place a service account JSON file in backend/ and point to it.

